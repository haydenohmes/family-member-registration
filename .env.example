# --- Option A: Gmail (no domain verification — testers receive the email) ---
# Use for user testing so testers can open the email in their own inbox.
# 1. Use a Gmail account. 2. Enable 2FA. 3. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Option B: Resend (needs verified domain to send to any recipient) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=Hudl <no-reply@no-reply.hudl.com>
# WAITLIST_EMAIL_TEST_REDIRECT=you@example.com
